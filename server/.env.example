# Copy to server/.env and adjust. In production (Netlify) set these as site
# environment variables instead — server/.env is never deployed.
PORT=8787
ADMIN_EMAIL=admin@rnbsnwriters.com
ADMIN_PASSWORD=change-me
SESSION_DAYS=30

# Public site origin (used in payment redirect URLs).
# On Netlify this defaults to the site URL automatically.
SITE_ORIGIN=http://localhost:5173

# --- Database ---
# Leave empty for local dev (uses server/data.sqlite).
# Production: create a Turso DB (turso db create) and set both values.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Payment gateways (each activates automatically when keys are set) ---
# Stripe: dashboard.stripe.com -> Developers -> API keys / Webhooks
# Webhook endpoint to register: https://YOUR-DOMAIN/api/webhooks/stripe (event: checkout.session.completed)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal: developer.paypal.com -> Apps & Credentials (REST API app)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
